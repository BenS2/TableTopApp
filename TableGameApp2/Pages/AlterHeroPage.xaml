<Page x:Class="TableGameApp2.Pages.AlterHeroPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:TableGameApp2.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="CreateHeroPage">

    <Grid>
        <TextBox HorizontalAlignment="Left" Margin="280,48,0,0" TextWrapping="Wrap" Text="TextBox" VerticalAlignment="Top" Width="120"/>
        <Label Content="Hero's Name" HorizontalAlignment="Left" Margin="172,48,0,0" VerticalAlignment="Top"/>
        <ListView d:ItemsSource="{d:SampleData ItemCount=5}" Margin="0,79,524,130" Name ="StatusesList">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Status Name" DisplayMemberBinding="{Binding Test1}" />
                    <GridViewColumn Header="Status Value" DisplayMemberBinding="{Binding Test2}" />
                </GridView>
            </ListView.View>
        </ListView>
        <Label Content="Select Hero" Name = "SelectHeroLabel"  HorizontalAlignment="Left" Margin="173,22,0,0" VerticalAlignment="Top" Width="78"/>
        <ComboBox HorizontalAlignment="Left" Name = "SelectHeroCombo"  Margin="280,22,0,0" VerticalAlignment="Top" Width="120"/>

    </Grid>
</Page>
