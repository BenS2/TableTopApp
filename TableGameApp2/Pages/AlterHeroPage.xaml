<Page x:Class="TableGameApp2.Pages.AlterHeroPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:TableGameApp2.Pages"
      mc:Ignorable="d" d:DesignWidth="900"
      Title="CreateHeroPage" Height="676">

    <Canvas Margin="0,0,10,0">
        <TextBox Name="HeroName" HorizontalAlignment="Left" Margin="280,48,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="120"/>
        <Label Content="Hero's Name" HorizontalAlignment="Left" Margin="172,48,0,0" VerticalAlignment="Top"/>
        <Label Content="Select Hero" Name = "SelectHeroLabel"  HorizontalAlignment="Left" Margin="173,22,0,0" VerticalAlignment="Top" Width="78"/>
        <ComboBox SelectionChanged="selectHero" HorizontalAlignment="Left" Name = "SelectHeroCombo"  Margin="280,22,0,0" VerticalAlignment="Top" Width="120"/>
        <DataGrid Name ="StatusesGrid"  Margin="26,79,474,397" SelectionUnit="Cell" AutoGenerateColumns = "False" MaxWidth="650" Width="400" Height="200">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Status Name" Binding = "{Binding statusName}"  />
                <DataGridTextColumn Header="Status Value" Binding = "{Binding statusValue}"  />
            </DataGrid.Columns>
        </DataGrid>
        <Button Name="SaveHeroes" Content="Save Heroes" Click = "OnSaveHeroes" HorizontalAlignment="Left" VerticalAlignment="Center" Width="165" RenderTransformOrigin="0.481,6.78" Height="46" Canvas.Left="426" Canvas.Top="284"/>
        <TextBox Name = "HeroNotes" AcceptsReturn="True" HorizontalAlignment="Left" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="276" Height="208" Canvas.Left="590" Canvas.Top="71"/>
        <Label Content="Hero Notes" Canvas.Left="590" Canvas.Top="44" RenderTransformOrigin="-0.553,0.327" HorizontalAlignment="Left" VerticalAlignment="Center"/>

    </Canvas>
</Page>
