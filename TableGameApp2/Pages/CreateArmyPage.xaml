<Page x:Class="TableGameApp2.Pages.CreateArmyPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:TableGameApp2.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="CreateArmyPage">

    <Canvas Margin="0,0,10,0">
        <DataGrid  Canvas.Left="27" Canvas.Top="84" Width="305">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Hero Name" Binding = "{Binding statusName}"  />
               
            </DataGrid.Columns>
        </DataGrid>
        <DataGrid  Canvas.Left="480" Canvas.Top="84" Width="300">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Hero Name" Binding = "{Binding statusName}"  />
            </DataGrid.Columns>
        </DataGrid>
        <Label Content="Army Name" HorizontalAlignment="Left" Margin="27,48,0,0" VerticalAlignment="Top"/>
        <ComboBox Name = "SelectArmyCombo" HorizontalAlignment="Left" Margin="27,13,0,0" VerticalAlignment="Top" Width="120"/>
        <TextBox HorizontalAlignment="Left" Margin="156,48,0,0" TextWrapping="Wrap" Text="TextBox" VerticalAlignment="Top" Width="120"/>
        <Button Name="SaveArmies" Content="Save Army" Canvas.Left="358" Canvas.Top="324"/>

    </Canvas>
</Page>
